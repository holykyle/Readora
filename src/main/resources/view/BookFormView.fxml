<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/20"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.readora.controller.BookFormViewController"
            stylesheets="@style.css"
            styleClass="root-pane">

    <top>
        <HBox alignment="CENTER_LEFT" styleClass="top-bar">
            <padding>
                <Insets top="14" right="24" bottom="14" left="24"/>
            </padding>

            <VBox spacing="0">
                <Label text="Readora" styleClass="logo-title"/>
                <Label text="Book Management Module" styleClass="logo-subtitle"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Back to Dashboard"
                    onAction="#handleBackToDashboard"
                    styleClass="secondary-action-button"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    fitToHeight="true"
                    pannable="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    styleClass="main-scroll">

            <content>
                <VBox spacing="22" styleClass="books-page">
                    <padding>
                        <Insets top="24" right="28" bottom="24" left="28"/>
                    </padding>

                    <VBox spacing="6">
                        <Label text="Book Management" styleClass="welcome-title"/>
                        <Label text="Add, edit, delete, search, and filter all library books from one page."
                               styleClass="welcome-subtitle"/>
                    </VBox>

                    <HBox spacing="20" fillHeight="true">

                        <VBox spacing="16" styleClass="form-panel" prefWidth="350" minWidth="320">
                            <Label text="Book Details" styleClass="section-heading"/>

                            <VBox spacing="8">
                                <Label text="Book ID" styleClass="form-label"/>
                                <TextField fx:id="bookIdField" promptText="Enter book ID"/>
                            </VBox>

                            <VBox spacing="8">
                                <Label text="Title" styleClass="form-label"/>
                                <TextField fx:id="titleField" promptText="Enter title"/>
                            </VBox>

                            <VBox spacing="8">
                                <Label text="Author" styleClass="form-label"/>
                                <TextField fx:id="authorField" promptText="Enter author"/>
                            </VBox>

                            <VBox spacing="8">
                                <Label text="Category" styleClass="form-label"/>
                                <ComboBox fx:id="categoryComboBox" promptText="Select category" maxWidth="1.7976931348623157E308"/>
                            </VBox>

                            <VBox spacing="8">
                                <Label text="Status" styleClass="form-label"/>
                                <ComboBox fx:id="statusComboBox" promptText="Select status" maxWidth="1.7976931348623157E308"/>
                            </VBox>

                            <HBox spacing="10">
                                <Button text="Add" onAction="#handleAddBook" styleClass="primary-action-button"/>
                                <Button text="Update" onAction="#handleUpdateBook" styleClass="secondary-action-button"/>
                                <Button text="Clear" onAction="#handleClearFields" styleClass="secondary-action-button"/>
                            </HBox>

                            <Button text="Delete Selected Book"
                                    onAction="#handleDeleteBook"
                                    styleClass="danger-wide-button"
                                    maxWidth="1.7976931348623157E308"/>

                            <Separator/>

                            <Label text="Search and Filter" styleClass="section-heading"/>

                            <VBox spacing="8">
                                <Label text="Search" styleClass="form-label"/>
                                <TextField fx:id="searchField"
                                           promptText="Search by Book ID, Title, or Author"
                                           onKeyReleased="#handleSearch"/>
                            </VBox>

                            <VBox spacing="8">
                                <Label text="Filter Category" styleClass="form-label"/>
                                <ComboBox fx:id="filterCategoryComboBox"
                                          onAction="#handleFilter"
                                          maxWidth="1.7976931348623157E308"/>
                            </VBox>

                            <VBox spacing="8">
                                <Label text="Filter Status" styleClass="form-label"/>
                                <ComboBox fx:id="filterStatusComboBox"
                                          onAction="#handleFilter"
                                          maxWidth="1.7976931348623157E308"/>
                            </VBox>
                        </VBox>

                        <VBox spacing="16" styleClass="table-panel" HBox.hgrow="ALWAYS">
                            <Label text="Book Records" styleClass="section-heading"/>

                            <TableView fx:id="bookTable" styleClass="book-table" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="bookIdColumn" text="Book ID" prefWidth="120"/>
                                    <TableColumn fx:id="titleColumn" text="Title" prefWidth="260"/>
                                    <TableColumn fx:id="authorColumn" text="Author" prefWidth="200"/>
                                    <TableColumn fx:id="categoryColumn" text="Category" prefWidth="160"/>
                                    <TableColumn fx:id="statusColumn" text="Status" prefWidth="140"/>
                                </columns>
                            </TableView>
                        </VBox>

                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>